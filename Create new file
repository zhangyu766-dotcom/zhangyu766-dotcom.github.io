<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Secure Checkout | NextGen Essentials</title>
    <meta name="description" content="Securely complete your premium service booking, customized horology consultation, or lookbook access.">
    <style>
        :root {
            --bg-color: #000000;
            --card-bg: #0c0c0e;
            --accent-gold: #c5a880;
            --text-main: #f5f5f7;
            --text-muted: #86868b;
            --border-color: #1f1f23;
            --success-green: #24b47e; /* Stripe官方标志性安全绿 */
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            line-height: 1.6;
            padding: 60px 24px;
            -webkit-font-smoothing: antialiased;
        }
        .checkout-container { max-width: 550px; margin: 0 auto; background-color: var(--card-bg); border: 1px solid var(--border-color); padding: 40px 30px; border-radius: 0px; }
        .back-link { color: var(--text-muted); text-decoration: none; font-size: 0.85em; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 30px; display: inline-block; transition: color 0.3s; }
        .back-link:hover { color: var(--accent-gold); }
        
        .brand-header { text-align: center; margin-bottom: 35px; }
        .brand-header h1 { font-size: 1.6em; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #fff; }
        .brand-header p { color: var(--text-muted); font-size: 0.9em; margin-top: 5px; }
        
        /* 订单摘要卡片 */
        .order-summary { border-top: 1px solid var(--border-color); border-bottom: 1px solid var(--border-color); padding: 20px 0; margin-bottom: 30px; }
        .item-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
        .item-name { font-size: 1.1em; font-weight: 600; color: #fff; }
        .item-desc { font-size: 0.9em; color: var(--text-muted); margin-bottom: 15px; }
        .price-total { display: flex; justify-content: space-between; font-size: 1.4em; font-weight: 700; color: var(--accent-gold); padding-top: 15px; border-top: 1px dashed var(--border-color); }
        
        /* 支付按钮设计 */
        .pay-button { width: 100%; background-color: #fff; color: #000; border: none; padding: 16px; font-size: 1em; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; cursor: pointer; transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1); margin-bottom: 20px; display: flex; justify-content: center; align-items: center; gap: 10px; }
        .pay-button:hover { background-color: var(--accent-gold); color: #000; transform: translateY(-2px); }
        
        .paypal-btn { background-color: #0070ba; color: #fff; }
        .paypal-btn:hover { background-color: #005ea6; color: #fff; }

        /* 安全保障声明 */
        .security-badge { display: flex; align-items: center; justify-content: center; gap: 8px; color: var(--success-green); font-size: 0.85em; font-weight: 500; letter-spacing: 0.5px; margin-top: 25px; }
        .security-badge svg { fill: var(--success-green); width: 16px; height: 16px; }
        
        footer { margin-top: 60px; text-align: center; font-size: 0.8em; color: var(--text-muted); }
    </style>
</head>
<body>
    <div class="checkout-container">
        <a href="index.html" class="back-link">← Cancel & Return</a>
        
        <div class="brand-header">
            <h1>NextGen Essentials</h1>
            <p>Secure Checkout Infrastructure</p>
        </div>
        
        <!-- 订单摘要信息区 -->
        <div class="order-summary">
            <div class="item-row">
                <span class="item-name">Premium Consult & Support</span>
                <span class="item-name" style="color:#fff">$49.00</span>
            </div>
            <p class="item-desc">1-on-1 Personalized Horology Modding Guide or Minimalist Wardrobe Curation Strategy.</p>
            
            <div class="price-total">
                <span>Total Due:</span>
                <span>$49.00 USD</span>
            </div>
        </div>
        
        <!-- ⚡ 核心功能：双重安全快捷支付通道 -->
        <!-- 渠道一：对标罗技/Satechi的Stripe克隆风格标准信用卡通道 -->
        <!-- 💡 后续实操：只需把 onclick 后面的链接换成你注册好的 Stripe Payment Link 即可一键通电 -->
        <button class="pay-button" onclick="window.location.href='https://buy.stripe.com/demo_link_placeholder'">
            Pay with Credit Card / Apple Pay
        </button>
        
        <!-- 渠道二：全球硬通货 PayPal 快捷通道 -->
        <!-- 💡 后续实操：只需把 onclick 后面的链接换成你的 PayPal 个人收款或商家链接即可 -->
        <button class="pay-button paypal-btn" onclick="window.location.href='https://www.paypal.com/paypalme/your_account_placeholder'">
            Pay with PayPal
        </button>
        
        <!-- 国际标准的工业级合规安全标识，给海外用户吃定心丸 -->
        <div class="security-badge">
            <svg viewBox="0 0 24 24"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1 .9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/></svg>
            SSL Encrypted & 100% Secure Payment Processing
        </div>
        
        <footer>
            <p>&copy; 2026 NextGen Essentials. PCI-DSS Compliant Pipeline.</p>
        </footer>
    </div>
</body>
</html>
